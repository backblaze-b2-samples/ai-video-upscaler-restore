# Backblaze B2 (required) — S3-compatible API only.
# The S3 endpoint is derived from B2_REGION as
# https://s3.<B2_REGION>.backblazeb2.com, so there is no separate
# endpoint variable to keep in sync.
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_b2_region

# Optional: public base URL for objects in a public bucket. Leave blank
# for private buckets (the app serves objects via short-lived presigned
# URLs instead).
B2_PUBLIC_URL_BASE=

# Optional: compute device for the restoration engine. Leave blank to
# auto-detect (CUDA → Apple MPS → CPU). Set to cpu, cuda, cuda:0, or mps
# to force one (e.g. RESTORATION_DEVICE=cpu if a GPU runs out of memory).
RESTORATION_DEVICE=

# Example of what filled-in values look like (fake — for visual reference only):
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-restoration-archive
# B2_REGION=us-west-004
# B2_PUBLIC_URL_BASE=https://my-restoration-archive.s3.us-west-004.backblazeb2.com
